<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_marginBottom="12dp"
    android:layout_marginHorizontal="4dp"
    android:background="#FFFFFF"
    android:elevation="4dp"> <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical">

    <TextView
        android:id="@+id/tvRowId"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/tvRowSiteName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Site Name"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#333333"/>

    <Button
        android:id="@+id/btnEditRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✏️ Edit"
        style="?android:attr/borderlessButtonStyle"
        android:textColor="#4CAF50"
        android:minHeight="0dp"
        android:padding="8dp"/>
</LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="12dp"
        android:background="#F5F5F5"
        android:paddingHorizontal="12dp"
        android:paddingVertical="4dp">

        <EditText
            android:id="@+id/etQuickPassword"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:inputType="textPassword"
            android:background="@null"
            android:focusable="false"
            android:clickable="false"
            android:cursorVisible="false"
            android:textSize="16sp"
            android:textColor="#555555"/>

        <CheckBox
            android:id="@+id/cbQuickShow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Show"
            android:textSize="14sp"
            android:buttonTint="#888888"/>

        <Button
            android:id="@+id/btnQuickCopy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Copy"
            style="?android:attr/borderlessButtonStyle"
            android:textColor="#2196F3"
            android:minHeight="0dp"
            android:padding="8dp"/>
    </LinearLayout>

</LinearLayout>